# Server
FERROCRAWL_HOST=0.0.0.0
FERROCRAWL_PORT=3400

# Timeouts & limits
FERROCRAWL_TIMEOUT_SECS=30
FERROCRAWL_MAX_BODY_SIZE=10485760
FERROCRAWL_MAX_CONCURRENT=50

# Cache
FERROCRAWL_CACHE_TTL=300
FERROCRAWL_CACHE_MAX=1000

# Authentication (comma-separated API keys, leave empty to disable auth)
FERROCRAWL_API_KEYS=

# LLM extraction (required for /v1/extract endpoint)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Logging
RUST_LOG=ferrocrawl=info,tower_http=info
